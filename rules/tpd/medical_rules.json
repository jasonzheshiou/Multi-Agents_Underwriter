{
  "benefit_type": "tpd",
  "version": "1.0.0",
  "last_updated": "2025-05-19",
  "description": "Deterministic medical underwriting rules for Total & Permanent Disability (TPD) Cover. Covers occupation-based disability criteria, injury types, recovery expectations, pre-existing conditions, age-based risk, and mental health considerations. TPD assessment differs from death cover — focus is on functional capacity to return to own occupation. FOR EDUCATIONAL USE ONLY.",
  "rules": [
    {
      "rule_id": "TPD-M-001",
      "category": "occupation_disability_criteria",
      "condition": "applicant.occupation_class == 1 and applicant.occupational_demand == 'cognitive'",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Occupation Class 1 with cognitive demand — professional/office role. Disability requires significant functional impairment in cognitive tasks. Standard terms if no other risk factors.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "TPD-M-002",
      "category": "occupation_disability_criteria",
      "condition": "applicant.occupation_class == 2 and applicant.occupational_demand == 'physical_light'",
      "action": "flag",
      "severity": "low",
      "recommendation": "case_by_case",
      "description": "Occupation Class 2 with light physical demand — surveyor, farmer. Even partial physical impairment may prevent return to work. Requires functional capacity assessment.",
      "additional_evidence": ["functional_capacity_evaluation", "occupational_report"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-M-003",
      "category": "occupation_disability_criteria",
      "condition": "applicant.occupation_class == 3 and applicant.occupational_demand == 'physical_medium'",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_or_refer",
      "loading_range": [1.25, 2.0],
      "description": "Occupation Class 3 with medium physical demand — tradesperson, construction. Physical injuries more likely to prevent return. May attract loading or require specialist report.",
      "additional_evidence": ["functional_capacity_evaluation", "physiotherapy_report"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-M-004",
      "category": "occupation_disability_criteria",
      "condition": "applicant.occupation_class == 4 and applicant.occupational_demand == 'physical_heavy'",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Occupation Class 4 with heavy physical demand — mining, forestry, heavy machinery. Any injury with even moderate recovery time likely to prevent return. Requires detailed functional assessment.",
      "additional_evidence": ["functional_capacity_evaluation", "specialist_orthopaedic_report", "vocational_rehabilitation_assessment"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-005",
      "category": "occupation_disability_criteria",
      "condition": "applicant.occupation_class == 5 and applicant.occupational_demand == 'hazardous'",
      "action": "refer",
      "severity": "critical",
      "recommendation": "manual_underwriting_or_decline",
      "description": "Occupation Class 5 with hazardous demand — underground mining, commercial diving, bushfire fighting. High disability risk. Injury or illness likely to result in permanent incapacity. Senior underwriter assessment required.",
      "additional_evidence": ["specialist_report", "functional_capacity_evaluation", "employer_statements"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-010",
      "category": "injury_type_recovery",
      "condition": "applicant.injury_type == 'spinal' and applicant.recovery_expected == 'incomplete'",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Spinal injury with incomplete recovery expected. Spinal conditions have high rate of permanent functional limitation. Requires specialist orthopaedic or neurosurgeon report with prognosis.",
      "additional_evidence": ["spinal_mri", "orthopaedic_surgeon_report", "pain_management_records"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-011",
      "category": "injury_type_recovery",
      "condition": "applicant.injury_type == 'amputation'",
      "action": "flag",
      "severity": "high",
      "recommendation": "loading_or_standard",
      "loading_range": [1.5, 3.0],
      "description": "Amputation. Permanent loss of function. Loading depends on residual limb, occupation, and adaptability of workplace. Upper limb amputation for manual worker = higher loading.",
      "additional_evidence": ["surgeon_report", "prosthetic_assessment", "vocational_assessment"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-012",
      "category": "injury_type_recovery",
      "condition": "applicant.injury_type == 'head_trauma' and applicant.concussion_history > 3",
      "action": "refer",
      "severity": "critical",
      "recommendation": "neurological_assessment_required",
      "description": "Repeated head trauma (3+ concussions). High risk of chronic traumatic encephalopathy and cognitive decline. Requires comprehensive neuropsychological assessment.",
      "additional_evidence": ["neurological_assessment", "neuropsychological_testing", "brain_imaging"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-013",
      "category": "injury_type_recovery",
      "condition": "applicant.injury_type == 'musculoskeletal' and applicant.recovery_expected == 'full'",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Musculoskeletal injury with expected full recovery. If recovery timeline is clear and prognosis is good, standard terms may apply after initial waiting period.",
      "additional_evidence": ["physiotherapy_progress_report"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "TPD-M-014",
      "category": "injury_type_recovery",
      "condition": "applicant.injury_type == 'cardiac' and applicant.recovery_expected == 'partial'",
      "action": "refer",
      "severity": "high",
      "recommendation": "cardiologist_assessment",
      "description": "Cardiac injury with partial recovery expected. Risk of further cardiac events affects both disability and longevity. Requires cardiologist report with return-to-work opinion.",
      "additional_evidence": ["cardiologist_report", "exercise_ecg", "echocardiogram"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-020",
      "category": "pre_existing_condition_impact",
      "condition": "applicant.has_pre_existing('chronic_back_condition') and applicant.current_exacerbation == True",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Pre-existing chronic back condition with current exacerbation. High risk that current episode leads to permanent incapacity. Requires detailed occupational and medical history.",
      "additional_evidence": ["gp_clinical_notes", "imaging_results", "physiotherapy_records", "employer_occupational_report"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-021",
      "category": "pre_existing_condition_impact",
      "condition": "applicant.has_pre_existing('cancer') and applicant.treatment_completed == False",
      "action": "refer",
      "severity": "critical",
      "recommendation": "postpone_or_decline",
      "description": "Active cancer treatment. Disability risk is indeterminate until treatment outcome known. Standard practice is to postpone assessment until 12 months post-treatment completion.",
      "additional_evidence": ["oncologist_report", "treatment_summary", "follow_up_imaging"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-022",
      "category": "pre_existing_condition_impact",
      "condition": "applicant.has_pre_existing('diabetes') and applicant.has_complications(['neuropathy', 'retinopathy', 'nephropathy'])",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_applied",
      "loading_range": [1.25, 1.75],
      "description": "Pre-existing diabetes with multiple complications. Progressive condition with increasing disability risk. Loading reflects escalating long-term risk.",
      "additional_evidence": ["endocrinologist_report", "hba1c_history", "complication_assessment"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-M-023",
      "category": "pre_existing_condition_impact",
      "condition": "applicant.has_pre_existing('mental_health') and applicant.treatment_adherence == 'Poor'",
      "action": "refer",
      "severity": "moderate",
      "recommendation": "psychiatric_assessment",
      "description": "Pre-existing mental health condition with poor treatment adherence. Risk of relapse and functional impairment is elevated. Requires current psychiatric assessment.",
      "additional_evidence": ["psychiatrist_report", "mental_health_treatment_plan", "medication_history"],
      "apra_ref": "LICOP - Underwriting Standards",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-M-030",
      "category": "age_disability_risk",
      "condition": "applicant.age < 30 and applicant.injury_severity == 'moderate'",
      "action": "flag",
      "severity": "low",
      "recommendation": "case_by_case",
      "description": "Young applicant (<30) with moderate injury. Generally good recovery prospects due to younger age. However, younger workers may have fewer accommodations available. Assess vocational rehabilitation potential.",
      "additional_evidence": ["vocational_rehabilitation_assessment"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "TPD-M-031",
      "category": "age_disability_risk",
      "condition": "30 <= applicant.age <= 50 and applicant.injury_severity == 'moderate'",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "functional_assessment_required",
      "description": "Middle-aged applicant (30-50) with moderate injury. This age group faces significant barriers returning to manual occupations. Functional capacity evaluation essential.",
      "additional_evidence": ["functional_capacity_evaluation", "vocational_assessment"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-M-032",
      "category": "age_disability_risk",
      "condition": "51 <= applicant.age <= 60 and applicant.injury_severity == 'moderate'",
      "action": "refer",
      "severity": "high",
      "recommendation": "vocational_rehabilitation_review",
      "description": "Pre-retirement age (51-60) with moderate injury. Older workers face greater difficulty retraining. Assess transferable skills and retirement proximity. May attract loading.",
      "additional_evidence": ["vocational_assessment", "transferable_skills_analysis", "retirement_timeline"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-033",
      "category": "age_disability_risk",
      "condition": "applicant.age > 60",
      "action": "refer",
      "severity": "high",
      "recommendation": "retirement_proximity_assessment",
      "description": "Applicant over 60. Proximity to retirement age affects disability definition and benefit period. Some policies have reduced TPD cover after age 60. Verify policy terms.",
      "additional_evidence": ["retirement_plan_declaration", "superannuation_statement"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-040",
      "category": "mental_health_tpd",
      "condition": "applicant.has_mental_health_condition('depression') and applicant.duration_months >= 6",
      "action": "refer",
      "severity": "moderate",
      "recommendation": "psychiatric_assessment",
      "description": "Depression lasting 6+ months. Prolonged depression can cause significant functional impairment affecting cognitive capacity, concentration, and social interaction required for work.",
      "additional_evidence": ["psychiatrist_report", "mental_functioning_questionnaire", "treating_therapist_report"],
      "apra_ref": "LICOP - Underwriting Standards",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-M-041",
      "category": "mental_health_tpd",
      "condition": "applicant.has_mental_health_condition('anxiety') and applicant.functional_impairment >= 'moderate'",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "case_by_case",
      "description": "Anxiety with moderate functional impairment. Mental health TPD assessment requires individualised evaluation per Life Insurance Code of Practice. Blanket exclusions are not acceptable.",
      "additional_evidence": ["psychologist_report", "mental_functioning_questionnaire", "occupational_capacity_assessment"],
      "apra_ref": "LICOP - Underwriting Standards",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-M-042",
      "category": "mental_health_tpd",
      "condition": "applicant.has_mental_health_condition('ptsd') and applicant.trauma_related_to_work == True",
      "action": "refer",
      "severity": "high",
      "recommendation": "specialist_trauma_assessment",
      "description": "PTSD with work-related trauma origin. Complex case requiring specialist trauma assessment. Work-related PTSD may have workers compensation implications.",
      "additional_evidence": ["trauma_specialist_report", "psychological_testing", "workers_comp_status"],
      "apra_ref": "LICOP - Underwriting Standards",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-043",
      "category": "mental_health_tpd",
      "condition": "applicant.has_mental_health_condition('psychosis')",
      "action": "refer",
      "severity": "critical",
      "recommendation": "psychiatric_assessment_required",
      "description": "Psychosis or psychotic disorder. Requires current psychiatrist report detailing stability, insight, treatment response, and functional capacity. High disability risk if untreated.",
      "additional_evidence": ["psychiatrist_report", "medication_stability_records", "family_collateral_history"],
      "apra_ref": "LICOP - Underwriting Standards",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-050",
      "category": "substance_abuse",
      "condition": "applicant.substance_abuse == 'Current' and applicant.substance_type == 'opioids'",
      "action": "refer",
      "severity": "critical",
      "recommendation": "manual_underwriting_or_decline",
      "description": "Current opioid abuse. High risk of functional impairment, overdose, and interaction with any prescribed medications. Likely decline or heavy loading pending rehabilitation.",
      "additional_evidence": ["drug_and_alcohol_assessment", "urine_toxicology_screen", "rehabilitation_plan"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-M-051",
      "category": "substance_abuse",
      "condition": "applicant.substance_abuse == 'Former' and applicant.recovery_years >= 5",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Former substance abuse with 5+ years sustained recovery. Long-term recovery is a strong positive indicator. Standard terms if no other risk factors present.",
      "additional_evidence": ["rehabilitation_certificates", "support_group_attendance_records"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    }
  ]
}
