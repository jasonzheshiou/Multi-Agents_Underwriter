{
  "benefit_type": "tpd",
  "version": "1.0.0",
  "last_updated": "2025-05-19",
  "description": "Deterministic financial underwriting rules for Total & Permanent Disability (TPD) Cover. Covers sum insured vs income replacement ratio, occupation class hazard mapping for disability, multiple policy ownership checks, previous TPD claim history, and superannuation fund coordination. TPD financial rules focus on income replacement adequacy rather than mortality risk. FOR EDUCATIONAL USE ONLY.",
  "rules": [
    {
      "rule_id": "TPD-F-001",
      "category": "income_replacement_ratio",
      "condition": "applicant.sum_insured <= applicant.annual_income * 2.0 and applicant.income_replacement_ratio <= 0.75",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Sum insured within 2x annual income and replacement ratio under 75%. Standard TPD benefit level — sufficient for income replacement without over-insurance risk.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "TPD-F-002",
      "category": "income_replacement_ratio",
      "condition": "applicant.income_replacement_ratio > 0.75 and applicant.income_replacement_ratio <= 0.85",
      "action": "flag",
      "severity": "low",
      "recommendation": "loading_applied",
      "loading_range": [1.05, 1.15],
      "description": "Income replacement ratio above 75% but within 85%. Some insurers cap TPD at 75-85% of pre-disability income to maintain return-to-work incentive. Minor loading may apply.",
      "additional_evidence": ["salary_sacrifice_declaration", "bonus_income_breakdown"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-003",
      "category": "income_replacement_ratio",
      "condition": "applicant.income_replacement_ratio > 0.85",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Income replacement ratio above 85%. Excessive replacement ratio may reduce incentive to return to work. Requires justification of need and verification of income components.",
      "additional_evidence": ["detailed_income_breakdown", "tax_returns", "business_financials", "justification_statement"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-F-010",
      "category": "occupation_disability_hazard",
      "condition": "applicant.occupation_class == 1 and applicant.disability_claim_frequency < 0.01",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Occupation Class 1 (professional/office) with low disability claim frequency. Cognitive-based roles have lower disability incidence than physical roles. Standard terms.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "TPD-F-011",
      "category": "occupation_disability_hazard",
      "condition": "applicant.occupation_class == 2 and applicant.disability_claim_frequency >= 0.01 and applicant.disability_claim_frequency < 0.02",
      "action": "flag",
      "severity": "low",
      "recommendation": "loading_applied",
      "loading_range": [1.1, 1.3],
      "description": "Occupation Class 2 (light field work) with moderate disability frequency. Roles like surveyor or farmer have higher physical injury risk. Loading applied.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-012",
      "category": "occupation_disability_hazard",
      "condition": "applicant.occupation_class == 3 and applicant.disability_claim_frequency >= 0.02",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_applied",
      "loading_range": [1.3, 1.75],
      "description": "Occupation Class 3 (trades/construction) with elevated disability frequency. Physical roles have higher injury rates and longer recovery periods. Moderate loading.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-013",
      "category": "occupation_disability_hazard",
      "condition": "applicant.occupation_class >= 4 and applicant.disability_claim_frequency >= 0.03",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Occupation Class 4+ (hazardous/manual) with high disability claim frequency. High-risk occupations require detailed underwriting. May attract significant loading or exclusion of specific hazards.",
      "additional_evidence": ["safety_record", "workplace_hazard_assessment", "workers_comp_history"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-F-020",
      "category": "multiple_policy_ownership",
      "condition": "applicant.total_tpd_cover > applicant.annual_income * 3.0",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "additional_disclosure",
      "description": "Total TPD cover across all policies exceeds 3x annual income. Industry standard cap to prevent moral hazard. Requires disclosure of all existing TPD policies.",
      "additional_evidence": ["life_insurance_register_check", "super_tpd_balance_statement", "insurable_interest_declaration"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-021",
      "category": "multiple_policy_ownership",
      "condition": "applicant.total_tpd_cover > applicant.annual_income * 5.0",
      "action": "refer",
      "severity": "high",
      "recommendation": "cap_and_refer",
      "description": "Total TPD cover exceeds 5x annual income. Significant over-insurance. May need to cap benefit at industry standard. Requires comprehensive financial needs assessment.",
      "additional_evidence": ["financial_needs_assessment", "debt_schedule", "dependant_information", "all_policy_disclosure"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-F-030",
      "category": "previous_tpd_claim",
      "condition": "applicant.previous_tpd_claim == True and applicant.claim_resolved == 'Paid'",
      "action": "refer",
      "severity": "critical",
      "recommendation": "manual_underwriting_or_decline",
      "description": "Previous TPD claim that was paid. Very high risk of re-disability. Most insurers will decline additional TPD cover. If offered, may be limited to accidental injury only.",
      "additional_evidence": ["previous_claim_details", "current_occupational_status", "medical_clearance", "return_to_work_evidence"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-F-031",
      "category": "previous_tpd_claim",
      "condition": "applicant.previous_tpd_claim == True and applicant.claim_resolved == 'Declined'",
      "action": "refer",
      "severity": "critical",
      "recommendation": "investigate_decline_reason",
      "description": "Previous TPD claim that was declined. Must investigate original decline reason. If medical, may affect new application. If administrative, may be less concerning.",
      "additional_evidence": ["original_decline_reason", "updated_medical_evidence", "current_occupational_status"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-F-032",
      "category": "previous_tpd_claim",
      "condition": "applicant.previous_tpd_claim == True and applicant.claim_resolved == 'Partial'",
      "action": "refer",
      "severity": "high",
      "recommendation": "partial_cover_assessment",
      "description": "Previous TPD claim with partial payout. Indicates ongoing functional limitations. New cover may be limited to unaffected disability components.",
      "additional_evidence": ["partial_claim_details", "functional_capacity_update", "current_treatment_plan"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "TPD-F-040",
      "category": "superannuation_coordination",
      "condition": "applicant.super_tpd_balance > 0 and applicant.has_group_tpd_in_super == True",
      "action": "flag",
      "severity": "low",
      "recommendation": "coordination_of_benefits",
      "description": "Applicant has TPD cover in superannuation (group policy). External TPD benefit will coordinate with group cover. Net benefit = external policy minus super TPD payout.",
      "additional_evidence": ["super_tpd_statement", "group_policy_details", "coordination_of_benefits_clause"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-041",
      "category": "superannuation_coordination",
      "condition": "applicant.super_tpd_balance > applicant.sum_insured * 0.5",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "reduce_external_cover",
      "description": "Super TPD balance exceeds 50% of requested external cover. Large super TPD balance means external benefit will be significantly reduced. Advise applicant on net benefit expectation.",
      "additional_evidence": ["super_statement", "benefit_coordination_calculation"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-042",
      "category": "superannuation_coordination",
      "condition": "applicant.super_tpd_balance == 0 and applicant.has_group_tpd_in_super == False",
      "action": "flag",
      "severity": "low",
      "recommendation": "recommend_super_tpd",
      "description": "No superannuation TPD cover. Applicant is entirely reliant on external policy. Recommend establishing super TPD as cost-effective top-up. External policy becomes sole income protection source.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-050",
      "category": "waiting_period",
      "condition": "applicant.requested_waiting_period <= 30",
      "action": "flag",
      "severity": "low",
      "recommendation": "loading_applied",
      "loading_range": [1.1, 1.3],
      "description": "Waiting period of 30 days or less. Short waiting period increases insurer exposure to short-term disabilities. Loading applied. Some insurers impose minimum 30-day waiting period.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-051",
      "category": "waiting_period",
      "condition": "30 < applicant.requested_waiting_period <= 90",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Waiting period between 31-90 days. Standard waiting period range. Balances premium cost with adequate gap before benefit commencement.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "TPD-F-052",
      "category": "waiting_period",
      "condition": "applicant.requested_waiting_period > 90",
      "action": "flag",
      "severity": "low",
      "recommendation": "loading_applied",
      "loading_range": [1.0, 1.15],
      "description": "Waiting period over 90 days. Longer waiting period reduces insurer risk. May attract slight discount loading. Verify applicant has sufficient savings to bridge extended waiting period.",
      "additional_evidence": ["emergency_fund_declaration"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-060",
      "category": "benefit_period",
      "condition": "applicant.requested_benefit_period == 'to_age_65' and applicant.age > 50",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "premium_impact_disclosure",
      "description": "Benefit period to age 65 with applicant over 50. Long benefit period for older applicant significantly increases premium. Must disclose premium impact and alternative benefit periods.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "TPD-F-061",
      "category": "benefit_period",
      "condition": "applicant.requested_benefit_period == '2_years'",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "2-year benefit period. Shorter benefit period reduces insurer exposure and premium cost. Common for younger applicants who have time to recover and retrain.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "TPD-F-070",
      "category": "income_verification",
      "condition": "applicant.income_type == 'self_employed' and applicant.income_verification == 'unverified'",
      "action": "refer",
      "severity": "high",
      "recommendation": "income_verification_required",
      "description": "Self-employed applicant with unverified income. High risk of income inflation. Requires tax returns, ASIC statements, or accountant verification before underwriting.",
      "additional_evidence": ["tax_returns_2_years", "asic_statement", "accountant_verification", "bank_statements"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    }
  ]
}
