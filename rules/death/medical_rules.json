{
  "benefit_type": "death",
  "version": "1.0.0",
  "last_updated": "2025-05-18",
  "description": "Deterministic medical underwriting rules for Death Cover. Sources: public Australian underwriting guidelines, APRA CPS 220, LICOP. FOR EDUCATIONAL USE ONLY.",
  "rules": [
    {
      "rule_id": "MED-D-001",
      "category": "bmi",
      "condition": "applicant.bmi < 18.5",
      "action": "refer",
      "severity": "moderate",
      "recommendation": "manual_underwriting",
      "description": "BMI below 18.5 - underweight. Refer for manual assessment.",
      "additional_evidence": ["gp_report", "blood_test"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-002",
      "category": "bmi",
      "condition": "18.5 <= applicant.bmi < 25",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "BMI within healthy range. Standard terms.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "MED-D-003",
      "category": "bmi",
      "condition": "25 <= applicant.bmi < 30",
      "action": "flag",
      "severity": "low",
      "recommendation": "standard_or_loading",
      "loading_range": [1.0, 1.25],
      "description": "BMI 25-30 - overweight. May attract loading if combined with other risk factors.",
      "additional_evidence": ["gp_report"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "MED-D-004",
      "category": "bmi",
      "condition": "30 <= applicant.bmi < 35",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_applied",
      "loading_range": [1.25, 1.75],
      "description": "BMI 30-35 - obese Class I. Loading applied.",
      "additional_evidence": ["gp_report", "blood_test_lipids", "blood_test_glucose"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-005",
      "category": "bmi",
      "condition": "35 <= applicant.bmi < 40",
      "action": "flag",
      "severity": "high",
      "recommendation": "loading_applied",
      "loading_range": [1.75, 2.5],
      "description": "BMI 35-40 - obese Class II. Significant loading. May require exercise ECG.",
      "additional_evidence": ["gp_report", "blood_test_lipids", "blood_test_glucose", "exercise_ecg"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "MED-D-006",
      "category": "bmi",
      "condition": "applicant.bmi >= 40",
      "action": "refer",
      "severity": "critical",
      "recommendation": "manual_underwriting_or_decline",
      "description": "BMI 40+ - obese Class III. Refer to senior underwriter. Likely decline or heavy loading.",
      "additional_evidence": ["specialist_report", "exercise_ecg", "full_blood_count"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "MED-D-010",
      "category": "smoker_status",
      "condition": "applicant.smoker_status == 'Never'",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Non-smoker. Standard terms.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "MED-D-011",
      "category": "smoker_status",
      "condition": "applicant.smoker_status == 'Former' and applicant.years_since_quit >= 1",
      "action": "flag",
      "severity": "low",
      "recommendation": "loading_applied",
      "loading_range": [1.25, 1.5],
      "description": "Former smoker, quit 1+ year ago. Reduced loading. After 1 year, cardiovascular risk begins to normalise.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-012",
      "category": "smoker_status",
      "condition": "applicant.smoker_status == 'Former' and applicant.years_since_quit < 1",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_applied",
      "loading_range": [1.5, 2.0],
      "description": "Former smoker, quit < 1 year. Loading applied. Body still recovering.",
      "additional_evidence": ["cotinine_test"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-013",
      "category": "smoker_status",
      "condition": "applicant.smoker_status == 'Current'",
      "action": "flag",
      "severity": "high",
      "recommendation": "loading_applied",
      "loading_range": [2.0, 3.5],
      "description": "Current smoker. Significant loading applied due to elevated mortality risk.",
      "additional_evidence": ["cotinine_test"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "MED-D-020",
      "category": "alcohol",
      "condition": "applicant.standard_drinks_per_week is not None and applicant.standard_drinks_per_week > 14",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_or_refer",
      "loading_range": [1.25, 2.0],
      "description": "Alcohol consumption exceeds NHMRC guidelines (>14 standard drinks per week).",
      "additional_evidence": ["liver_function_test", "gp_report"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-030",
      "category": "pre_existing_condition",
      "condition": "applicant.has_condition('cardiovascular_disease') and applicant.age > 50",
      "action": "refer",
      "severity": "critical",
      "recommendation": "manual_underwriting",
      "description": "Cardiovascular disease in applicant over 50. Requires specialist assessment.",
      "additional_evidence": ["cardiologist_report", "stress_ecg", "echocardiogram"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "MED-D-031",
      "category": "pre_existing_condition",
      "condition": "applicant.has_condition('diabetes_type_1')",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Type 1 diabetes. Requires detailed specialist assessment including HbA1c history.",
      "additional_evidence": ["endocrinologist_report", "hba1c_history", "renal_function_test"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "MED-D-032",
      "category": "pre_existing_condition",
      "condition": "applicant.has_condition('diabetes_type_2')",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_applied",
      "loading_range": [1.5, 2.5],
      "description": "Type 2 diabetes. Loading depends on control (HbA1c), complications, and duration.",
      "additional_evidence": ["hba1c_history", "gp_report"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-040",
      "category": "mental_health",
      "condition": "applicant.has_condition('anxiety') or applicant.has_condition('depression')",
      "action": "flag",
      "severity": "low_to_moderate",
      "recommendation": "case_by_case",
      "description": "Mental health condition. Life Insurance Code of Practice requires fair, evidence-based, individual assessment. Blanket exclusions are not acceptable.",
      "additional_evidence": ["mental_health_questionnaire", "treating_doctor_report"],
      "apra_ref": "LICOP - Underwriting Standards",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-041",
      "category": "mental_health",
      "condition": "applicant.has_condition('severe_mental_illness')",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Severe mental illness. Requires specialist psychiatric report. Must be assessed individually per LICOP.",
      "additional_evidence": ["psychiatrist_report", "mental_health_questionnaire"],
      "apra_ref": "LICOP - Underwriting Standards",
      "debate_priority": 1
    },
    {
      "rule_id": "MED-D-050",
      "category": "family_history",
      "condition": "applicant.check_family_history('cardiovascular_disease') and applicant.family_age_at_diagnosis < 60",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_or_additional_tests",
      "loading_range": [1.25, 1.5],
      "description": "Family history of early-onset cardiovascular disease (parent/sibling diagnosed before age 60).",
      "additional_evidence": ["blood_test_lipids", "resting_ecg"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-051",
      "category": "family_history",
      "condition": "applicant.check_family_history('cancer') and applicant.family_age_at_diagnosis < 50",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_or_additional_tests",
      "loading_range": [1.25, 1.5],
      "description": "Family history of early-onset cancer (parent/sibling diagnosed before age 50).",
      "additional_evidence": ["gp_report", "family_history_questionnaire"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-060",
      "category": "hazardous_pursuits",
      "condition": "applicant.has_hazardous_pursuit('skydiving') or applicant.has_hazardous_pursuit('rock_climbing') or applicant.has_hazardous_pursuit('motor_racing') or applicant.has_hazardous_pursuit('scuba_diving')",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "exclusion_or_loading",
      "loading_range": [1.5, 3.0],
      "description": "Hazardous pursuits. May attract exclusion for specific activity or premium loading.",
      "additional_evidence": ["activity_questionnaire"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "MED-D-070",
      "category": "recreational_drugs",
      "condition": "applicant.recreational_drug_use == True",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Recreational drug use. Requires detailed assessment of type, frequency, and recency.",
      "additional_evidence": ["drug_use_questionnaire", "liver_function_test"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "MED-D-080",
      "category": "multiple_conditions",
      "condition": "applicant.medical_conditions is not None and len(applicant.medical_conditions) >= 3",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Three or more pre-existing conditions. Interaction effects require senior underwriter assessment.",
      "additional_evidence": ["comprehensive_gp_report", "specialist_reports"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    }
  ]
}
