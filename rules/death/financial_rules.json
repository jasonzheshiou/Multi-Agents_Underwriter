{
  "benefit_type": "death",
  "version": "1.0.0",
  "last_updated": "2025-05-18",
  "description": "Deterministic financial underwriting rules for Death Cover. Covers sum-insured-to-income multiples by age, occupation class, previous declination, bankruptcy, and multiple policies. FOR EDUCATIONAL USE ONLY.",
  "rules": [
    {
      "rule_id": "FIN-D-001",
      "category": "income_multiple",
      "condition": "applicant.age <= 40 and applicant.sum_insured <= applicant.annual_income * 25",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Age 0-40: Sum insured within 25x income. Acceptable ratio for younger applicants.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "FIN-D-002",
      "category": "income_multiple",
      "condition": "applicant.age <= 40 and applicant.sum_insured > applicant.annual_income * 25",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_or_additional_info",
      "loading_range": [1.1, 1.5],
      "description": "Age 0-40: Sum insured exceeds 25x income. May attract loading or require additional financial justification.",
      "additional_evidence": ["proof_of_income", "asset_statement"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "FIN-D-003",
      "category": "income_multiple",
      "condition": "41 <= applicant.age <= 50 and applicant.sum_insured <= applicant.annual_income * 20",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Age 41-50: Sum insured within 20x income. Acceptable ratio for middle-aged applicants.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "FIN-D-004",
      "category": "income_multiple",
      "condition": "41 <= applicant.age <= 50 and applicant.sum_insured > applicant.annual_income * 20",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "loading_or_additional_info",
      "loading_range": [1.1, 1.5],
      "description": "Age 41-50: Sum insured exceeds 20x income. May attract loading or require additional financial justification.",
      "additional_evidence": ["proof_of_income", "asset_statement"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "FIN-D-005",
      "category": "income_multiple",
      "condition": "51 <= applicant.age <= 60 and applicant.sum_insured <= applicant.annual_income * 15",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Age 51-60: Sum insured within 15x income. Acceptable ratio for older applicants.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "FIN-D-010",
      "category": "income_multiple",
      "condition": "51 <= applicant.age <= 60 and applicant.sum_insured > applicant.annual_income * 15",
      "action": "flag",
      "severity": "high",
      "recommendation": "loading_applied",
      "loading_range": [1.25, 2.0],
      "description": "Age 51-60: Sum insured exceeds 15x income. Significant overage requires loading.",
      "additional_evidence": ["proof_of_income", "asset_statement", "debt_schedule"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "FIN-D-020",
      "category": "occupation_class",
      "condition": "applicant.occupation_class == 1",
      "action": "pass",
      "severity": "none",
      "recommendation": "standard",
      "description": "Occupation Class 1: Standard office/professional work (e.g., accountant, teacher). No loading.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 3
    },
    {
      "rule_id": "FIN-D-021",
      "category": "occupation_class",
      "condition": "applicant.occupation_class == 2",
      "action": "flag",
      "severity": "low",
      "recommendation": "loading_applied",
      "loading_range": [1.0, 1.25],
      "description": "Occupation Class 2: Light field work (e.g., surveyor, farmer). Minor loading may apply.",
      "additional_evidence": [],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    },
    {
      "rule_id": "FIN-D-030",
      "category": "previous_declination",
      "condition": "applicant.previous_declination == True",
      "action": "refer",
      "severity": "high",
      "recommendation": "manual_underwriting",
      "description": "Previous insurance declination. Requires manual underwriting review to understand original reason.",
      "additional_evidence": ["original_declination_reason", "medical_records_post_declination"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "FIN-D-040",
      "category": "bankruptcy",
      "condition": "applicant.bankruptcy_status == 'Current' or applicant.bankruptcy_status == 'Recent'",
      "action": "flag",
      "severity": "high",
      "recommendation": "loading_or_decline",
      "loading_range": [1.5, 3.0],
      "description": "Current or recent bankruptcy. Financial distress may indicate moral hazard. Loading or decline.",
      "additional_evidence": ["credit_report", "financial_stability_assessment"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 1
    },
    {
      "rule_id": "FIN-D-050",
      "category": "multiple_policies",
      "condition": "applicant.total_existing_policies > 3",
      "action": "flag",
      "severity": "moderate",
      "recommendation": "additional_disclosure",
      "description": "Applicant holds more than 3 existing policies. Requires additional disclosure and aggregation check.",
      "additional_evidence": ["life_insurance_register_check", "insurable_interest_declaration"],
      "apra_ref": "CPS 220 - Risk Assessment",
      "debate_priority": 2
    }
  ]
}
